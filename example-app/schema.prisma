datasource db {
  provider = "sqlite"
  url = "file:/home/ravi/Documents/prisma/dev.db"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
  MODERATOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String?
  role        Role     @default(USER)
  posts       Post[]
  profile     Profile?
}

model Profile {
  id     String @id @default(cuid())
  bio    String
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id        String     @id @default(cuid())
  title     String     @unique
  status    PostStatus @default(DRAFT)
  published Boolean    @default(false)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
}

model Comment {
  id      String @id @default(cuid())
  text    String
  postId  String
  post    Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
}
