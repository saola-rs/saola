datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
  MODERATOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  role  Role    @default(USER)
  posts Post[]
}

model Post {
  id        String     @id @default(cuid())
  title     String
  status    PostStatus @default(DRAFT)
  published Boolean    @default(false)
  userId    String
  user      User       @relation(fields: [userId], references: [id])
}

